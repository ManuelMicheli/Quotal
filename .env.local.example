# =============================================================================
# Quotal — Local environment variables
# =============================================================================
# Copy this file to `.env.local` and fill in the values. `.env.local` is
# gitignored. Never commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (required from Phase 01)
# -----------------------------------------------------------------------------
# Project URL, e.g. https://abcd1234.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Anon public key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (server-only, NEVER expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Stripe (required from Phase 05)
# -----------------------------------------------------------------------------
# Secret key (sk_test_... in test mode, sk_live_... in production)
STRIPE_SECRET_KEY=
# Webhook signing secret (whsec_...)
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Resend (required from Phase 09)
# -----------------------------------------------------------------------------
# API key (re_...)
RESEND_API_KEY=
# Verified sender email, e.g. no-reply@quotal.it
RESEND_FROM_EMAIL=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# Public app URL. In production set to https://quotal.it (or your domain).
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

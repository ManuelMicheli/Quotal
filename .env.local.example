# =============================================================================
# Quotal — Local environment variables
# =============================================================================
# Copy this file to `.env.local` and fill in the values. `.env.local` is
# gitignored. Never commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (required from Phase 01)
# -----------------------------------------------------------------------------
# Project URL, e.g. https://abcd1234.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Anon public key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (server-only, NEVER expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Stripe (required from Phase 05)
# -----------------------------------------------------------------------------
# Secret key (sk_test_... in test mode, sk_live_... in production).
# Server-only.
STRIPE_SECRET_KEY=
# Webhook signing secret (whsec_...). Different per environment / CLI session.
# When using Stripe CLI: `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# prints a `whsec_…` value — paste it here.
STRIPE_WEBHOOK_SECRET=
# Publishable key (pk_test_... / pk_live_...). Safe to expose to the browser.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# Resend (required from Phase 09)
# -----------------------------------------------------------------------------
# API key (re_...)
RESEND_API_KEY=
# Verified sender email — pass either a bare address or a "Display Name <addr>"
# string. Resend rejects unverified domains in production, so until you finish
# domain verification (`docs/email-setup.md`) keep this on the
# `onboarding@resend.dev` sandbox sender.
RESEND_FROM_EMAIL=Quotal <noreply@quotal.it>
# Optional Reply-To header on outbound mail.
RESEND_REPLY_TO=support@quotal.it
# Optional Resend webhook signing secret (set in Resend dashboard → Webhooks).
RESEND_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Web Push / VAPID (Phase 09)
# -----------------------------------------------------------------------------
# Generate a fresh keypair via `node scripts/gen-vapid.mjs`. The public key
# is also exposed to the browser so the SW can subscribe.
VAPID_PUBLIC_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Cron jobs (Phase 09)
# -----------------------------------------------------------------------------
# Shared secret used by Supabase pg_cron + Edge Functions to call
# /api/cron/* endpoints. Sent as `Authorization: Bearer <CRON_SECRET>`.
# Generate via `openssl rand -hex 32` (>= 16 chars). Empty value disables
# the cron endpoints entirely.
CRON_SECRET=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# Public app URL. In production set to https://quotal.it (or your domain).
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Security (Phase 10)
# -----------------------------------------------------------------------------
# Set to "true" to emit Content-Security-Policy in report-only mode (logs
# violations without enforcing). Recommended for the first 24h after deploy
# to confirm no legitimate request is blocked, then unset (or "false") to
# enforce.
CSP_REPORT_ONLY=
